#ifndef __MQTT_SECRETS_H__
#define __MQTT_SECRETS_H__

/* Copy this file to mqtt_secrets.h (gitignored) and fill in your own
 * OneNET (heclouds) device credentials from your OneNET product/device
 * console: username is the product ID, password is the device token,
 * client_id is the device name. */

#define MQTT_BROKER_URI "mqtt://mqtts.heclouds.com:1883"
#define MQTT_CLIENT_ID  "your-device-name"
#define MQTT_USERNAME   "your-product-id"
#define MQTT_PASSWORD   "your-device-token"

#endif
